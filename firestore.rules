rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read all users (for team members list)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Allow authenticated users to read and write quiz results
    match /quiz_results/{document=**} {
      allow create: if request.auth != null;
      allow read: if request.auth.uid == resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // Allow authenticated users to read and write groups
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      
      // Allow read/write to group subcollections
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Allow authenticated users to read and write tasks
    match /tasks/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write events
    match /events/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write resources
    match /resources/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write discussions
    match /discussions/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write activity
    match /activity/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
